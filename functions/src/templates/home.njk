{% extends "base.njk" %}

{% block content %}
  <section class="home-hero" aria-labelledby="home-title">
    <div class="hero-media" id="home-gallery" role="group" aria-roledescription="carousel" aria-label="Pluto Events photo gallery" data-gallery>
      {% set gallery = [
        { src: '1.webp', alt: 'Performers onstage behind pink caution tape at a Pluto Events party' },
        { src: 'elysium-10.webp', alt: 'Green and magenta light trails moving through a Pluto Events dance floor' },
        { src: '14.webp', alt: 'Two attendees dancing together at a Pluto Events party' },
        { src: 'elysium-4.webp', alt: 'Three friends smiling with their arms around each other at a Pluto Events party' },
        { src: '10.webp', alt: 'Three attendees posing together in front of a brick wall at a Pluto Events party' }
      ] %}
      {% for image in gallery %}
        <img src="/gallery/{{ image.src }}" width="1920" height="1080" alt="{{ image.alt }}" decoding="async" {% if loop.first %}loading="eager" fetchpriority="high"{% else %}hidden loading="lazy"{% endif %} data-gallery-slide>
      {% endfor %}
    </div>
    <div class="hero-shade"></div>
    <div class="hero-content">
      <p class="eyebrow">ASHEVILLE · UNDERGROUND · TOGETHER</p>
      <h1 id="home-title">PLUTO EVENTS</h1>
      <p class="hero-copy">Immersive parties and campouts built around heavy sound, local art, and the people who make the night.</p>
      <div class="hero-actions">
        <a class="button button-primary button-large" href="#events">See upcoming events</a>
        <a class="button button-glass button-large" href="/manafest">Explore ManaFest</a>
      </div>
    </div>
    <div class="gallery-controls" role="group" aria-label="Photo gallery controls">
      <button type="button" data-gallery-previous aria-label="Previous photo" aria-controls="home-gallery">←</button>
      <span data-gallery-status role="status" aria-live="polite" aria-atomic="true" aria-label="Photo 1 of 5">1 / 5</span>
      <button type="button" data-gallery-next aria-label="Next photo" aria-controls="home-gallery">→</button>
    </div>
  </section>

  <section class="section events-section" id="events" aria-labelledby="events-title">
    <div class="section-heading">
      <div><p class="eyebrow">WHAT'S NEXT</p><h2 id="events-title">Upcoming events</h2></div>
      <p>Tickets, details, and everything you need before you arrive.</p>
    </div>
    <div class="event-grid">
      {% for event in events %}
        <article class="event-card" aria-labelledby="event-{{ loop.index }}-title">
          {% if event.flyerImageUrl %}
            <img class="deferred-event-image" src="/assets/images/pluto-logo.webp" data-deferred-src="{{ event.flyerImageUrl }}" width="900" height="1200" alt="{{ event.title }} event artwork" loading="lazy" decoding="async" fetchpriority="low">
          {% else %}
            <div class="event-art-fallback" aria-hidden="true">PLUTO</div>
          {% endif %}
          <div class="event-card-body">
            <h3 id="event-{{ loop.index }}-title">{{ event.title }}</h3>
            {% if event.details %}<p>{{ event.details }}</p>{% endif %}
            <div class="event-actions">
              {% if event.ticketUrl %}<a class="button button-primary" href="{{ event.ticketUrl }}" target="_blank" rel="noopener noreferrer">Get tickets</a>{% endif %}
              {% if event.isManaFest %}<a class="button button-quiet" href="/manafest">ManaFest details</a>{% endif %}
            </div>
          </div>
        </article>
      {% else %}
        <p class="empty-state">New events are being prepared. Check back soon.</p>
      {% endfor %}
    </div>
  </section>

  <section class="statement-band" aria-labelledby="community-title">
    <p class="eyebrow">BUILT FOR PARTICIPATION</p>
    <h2 id="community-title">The crowd is part of the show.</h2>
    <p>Come expressive. Look out for each other. Leave the space better than you found it.</p>
    <a class="text-link" href="/links">Find Pluto online →</a>
  </section>
{% endblock %}
